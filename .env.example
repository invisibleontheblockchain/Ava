# Database
DATABASE_URL=postgresql+asyncpg://ava:ava@localhost:5432/ava
LANGGRAPH_DATABASE_URL=postgresql://ava:ava@localhost:5432/ava

# Redis (ARQ + SSE pub/sub)
REDIS_URL=redis://localhost:6379/0

# LLM (Phase 1: single provider via LiteLLM)
OPENAI_API_KEY=
LITELLM_MODEL=gpt-4o
# Set true for Phase 1 testing without API keys
MOCK_LLM=false
ARTIFACTS_DIR=./data/artifacts

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Connectors (Phase 3 — optional Nango self-host: docker compose --profile connectors up)
NANGO_URL=http://localhost:3003
NANGO_SECRET_KEY=
MOCK_CONNECTORS=true

# Phase 4/5
REPLICATE_API_KEY=
EE_LICENSE_KEY=
COLLAB_WS_URL=ws://localhost:1234
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_BUCKET=ava-artifacts
LLM_REQUESTS_PER_MINUTE=60

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_COLLAB_WS_URL=ws://localhost:1234
